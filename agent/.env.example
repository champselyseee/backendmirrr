# xAI / Grok
XAI_API_KEY=xai-...
XAI_MODEL=grok-3-mini

# Google Таблица
# ID берёшь из URL: https://docs.google.com/spreadsheets/d/ВОТ_ЭТО/edit
SPREADSHEET_ID=

# Папки на Google Drive
# ID берёшь из URL папки: https://drive.google.com/drive/folders/ВОТ_ЭТО
DRIVE_FOLDER_EMAILS=
DRIVE_FOLDER_SOCHIN=
DRIVE_FOLDER_ESSE=

# Файл service account (лежит рядом с main.py)
GOOGLE_SERVICE_ACCOUNT=service_account.json
